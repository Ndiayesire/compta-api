        {
          "name": "Update user",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/users/:id"
          }
        },
        {
          "name": "Set role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"roleId\": \"a0000016-0000-4000-8000-000000000001\"\n}" },
            "url": "{{baseUrl}}/users/:id/role"
          }
        },
        {
          "name": "Unset role",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/users/:id/role" }
        },
        {
          "name": "Deactivate user",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/users/:id" }
        }
      ]
    },
