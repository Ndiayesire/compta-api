              "raw": "{\n  \"email\": \"new.user@example.com\",\n  \"password\": \"SecurePass12\",\n  \"roleId\": \"a0000016-0000-4000-8000-000000000001\",\n  \"countryId\": \"a0000002-0000-4000-8000-000000000001\",\n  \"regionId\": \"a0000003-0000-4000-8000-000000000001\",\n  \"languageId\": \"a0000004-0000-4000-8000-000000000001\",\n  \"genderId\": \"a0000007-0000-4000-8000-000000000001\",\n  \"firstName\": \"A\",\n  \"lastName\": \"B\",\n  \"phone\": \"+221770000001\",\n  \"address\": \"Dakar\",\n  \"avatar\": \"\"\n}"
