{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-comptaapi01",
    "name": "Insta Compta API",
    "description": "NestJS compta-api — import into Postman. Set collection variables `baseUrl` (e.g. http://localhost:4230) and `accessToken` after Login. Most routes use JWT Bearer auth (global guard).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4230" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "App",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@localhost.dev\",\n  \"password\": \"Admin123!dev\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Public. Copy accessToken / refreshToken into collection variables."
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass12\",\n  \"roleId\": \"a0000016-0000-4000-8000-000000000001\",\n  \"countryId\": \"a0000002-0000-4000-8000-000000000001\",\n  \"regionId\": \"a0000003-0000-4000-8000-000000000001\",\n  \"languageId\": \"a0000004-0000-4000-8000-000000000001\",\n  \"genderId\": \"a0000007-0000-4000-8000-000000000001\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Dupont\",\n  \"phone\": \"+221770000000\",\n  \"address\": \"Dakar\",\n  \"avatar\": \"\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Refresh tokens",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Me (auth profile)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
