datasource db {
  provider = "mysql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISSOLVED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PaymentMethodType {
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  CASH
  CRYPTO
  OTHER
}

//////////////////////////////////////////////////////
// REGION / COUNTRY / CURRENCY
//////////////////////////////////////////////////////

model Country {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  regions   Region[]  @relation("CountryRegions")
  companies Company[]
  clients   Client[]

  @@map("countries")
}

model Region {
  id        String    @id @default(uuid())
  name      String
  countryId String    @map("country_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  country   Country   @relation("CountryRegions", fields: [countryId], references: [id])
  companies Company[]
  clients   Client[]

  @@index([countryId])
  @@map("regions")
}

model Currency {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  symbol    String?
  decimals  Int       @default(0)
  isPrefix  Boolean   @default(false) @map("is_prefix")
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  companies Company[]
  clients   Client[]

  @@map("currencies")
}

//////////////////////////////////////////////////////
// PAYMENT METHODS
//////////////////////////////////////////////////////

model PaymentMethod {
  id        String            @id @default(uuid())
  name      String
  code      String            @unique
  type      PaymentMethodType
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  companies CompanyPaymentMethod[]

  @@map("payment_methods")
}

model CompanyPaymentMethod {
  id              String        @id @default(uuid())
  companyId       String        @map("company_id")
  paymentMethodId String        @map("payment_method_id")
  isDefault       Boolean       @default(false) @map("is_default")
  createdAt       DateTime      @default(now()) @map("created_at")

  company         Company       @relation(fields: [companyId], references: [id])
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@unique([companyId, paymentMethodId])
  @@index([companyId])
  @@index([paymentMethodId])
  @@map("company_payment_methods")
}

//////////////////////////////////////////////////////
// COMPANY / LEGALFORM
//////////////////////////////////////////////////////

model Company {
  id          String        @id @default(uuid())
  name        String
  siret       String?       @unique
  vatNumber   String?       @unique @map("vat_number")
  legalFormId String?       @map("legal_form_id")
  status      CompanyStatus @default(ACTIVE)
  nafCode     String?       @map("naf_code")

  address      String?

  countryId String?  @map("country_id")
  regionId  String?  @map("region_id")

  email       String?
  phone       String?
  website     String?

  currencyId      String?   @map("currency_id")
  isHolding       Boolean   @default(false) @map("is_holding")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  legalForm      LegalForm?             @relation(fields: [legalFormId], references: [id])
  country        Country?               @relation(fields: [countryId], references: [id])
  region         Region?                @relation(fields: [regionId], references: [id])
  currency       Currency?              @relation(fields: [currencyId], references: [id])
  users          User[]
  paymentMethods CompanyPaymentMethod[]
  clients        Client[]

  @@index([status])
  @@index([deletedAt])
  @@index([name])
  @@index([countryId])
  @@index([regionId])
  @@index([currencyId])
  @@index([legalFormId])
  @@map("companies")
}

model LegalForm {
  id        String    @id @default(uuid())
  name      String    @unique
  description String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  companies Company[]
  clients   Client[]

  @@map("legal_forms")
}

//////////////////////////////////////////////////////
// AUTH / USERS
//////////////////////////////////////////////////////

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  action      String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  isActive  Boolean   @default(true) @map("is_active")

  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  firstName   String?    @map("first_name")
  lastName    String?    @map("last_name")
  phone       String?
  address     String?
  avatar      String?
  status      UserStatus @default(ACTIVE)
  isActive    Boolean    @default(true) @map("is_active")

  companyId   String?    @map("company_id")
  roleId      String?    @map("role_id")
  lastLoginAt DateTime?  @map("last_login_at")
  refreshToken String?   @map("refresh_token") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company Company? @relation(fields: [companyId], references: [id])
  role    Role?    @relation(fields: [roleId], references: [id])

  @@index([email])
  @@index([companyId])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

//////////////////////////////////////////////////////
// CLIENTS / CLIENT TYPES / CLIENT FLAGS
//////////////////////////////////////////////////////

model ClientType {
  id        String    @id @default(uuid())
  name      String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  clients   Client[]
}

model ClientFlag {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  class     String
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  clients   Client[]
}

model Client {
  id           String       @id @default(uuid())
  companyId    String       @map("company_id")
  clientTypeId String?      @map("client_type_id")
  clientFlagId String?      @map("client_flag_id")
  countryId    String?      @map("country_id")
  regionId     String?      @map("region_id")
  currencyId   String?      @map("currency_id")
  legalFormId  String?      @map("legal_form_id")

  siret       String?      @unique
  vatNumber   String?      @unique @map("vat_number")
  nafCode     String?      @map("naf_code")

  name        String
  email       String?      @unique
  phone       String?
  address     String?
  isActive  Boolean   @default(true) @map("is_active")

  deletedAt   DateTime?    @map("deleted_at")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  clientType  ClientType?  @relation(fields: [clientTypeId], references: [id])
  clientFlag  ClientFlag?  @relation(fields: [clientFlagId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id])
  country     Country?     @relation(fields: [countryId], references: [id])
  region      Region?      @relation(fields: [regionId], references: [id])
  currency    Currency?    @relation(fields: [currencyId], references: [id])
  legalForm   LegalForm?   @relation(fields: [legalFormId], references: [id])

  @@index([companyId])
  @@index([clientTypeId])
  @@index([clientFlagId])
  @@index([countryId])
  @@index([regionId])
  @@index([currencyId])
  @@index([legalFormId])
  @@index([deletedAt])
  @@map("clients")
}